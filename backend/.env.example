# MongoDB connection string (local or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/task-manager

# Secret used to sign JWT tokens - use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret

# Port the API server listens on
PORT=5000

# Gmail account used to send notification emails
# NOTE: you must use a Gmail "App Password", not your normal Gmail password.
# Create one at https://myaccount.google.com/apppasswords (requires 2-Step Verification enabled).
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# URL of the frontend, used inside notification emails as a link back to the app
FRONTEND_URL=http://localhost:5173
